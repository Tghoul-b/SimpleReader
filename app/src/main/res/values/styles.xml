<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="NoPaddingToolbar" parent="Base.Widget.AppCompat.Toolbar">
        <item name="contentInsetStartWithNavigation">0dp</item>
    </style>
    <style name="read_setting_button" >
        <item name="android:gravity">center_horizontal|bottom</item>
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">12sp</item>
    </style>
    <style name="NoStatusStyle" >
        <item name="android:windowTranslucentStatus">true</item>    <!--状态栏为透明,如果设置为false，则没有黑色条盖住，见下图对比-->
        <item name="android:windowTranslucentNavigation">true</item> <!--导航栏为透明-->
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

</resources>